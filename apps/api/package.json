{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "API service for Figtree",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts -p=4000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "dotenv-flow -e .env -- pnpm --filter=@figtree/prisma generate",
    "prisma:push": "dotenv-flow -e .env -- pnpm --filter=@figtree/prisma push",
    "prisma:studio": "dotenv-flow -e .env -- pnpm --filter=@figtree/prisma studio",
    "prisma:validate": "dotenv-flow -e .env -- pnpm --filter=@figtree/prisma validate",
    "prisma:seed": "dotenv-flow -e .env -- pnpm --filter=@figtree/prisma seed"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@figtree/features": "workspace:*",
    "@figtree/lib": "workspace:*",
    "@figtree/modules": "workspace:*",
    "@figtree/prisma": "workspace:*",
    "@figtree/shared": "workspace:*",
    "@figtree/utils": "workspace:*",
    "dotenv": "^17.4.2",
    "dotenv-flow": "^4.1.0",
    "dotenv-flow-cli": "^1.1.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@figtree/eslint-config": "workspace:^",
    "@figtree/typescript-config": "workspace:*",
    "@types/node": "^24.12.2",
    "typescript": "^5.9.3"
  }
}
