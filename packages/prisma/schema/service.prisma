enum PricingType {
  one_time
  instalment
  recurring     // ◄ Triggers the Retainer layer
}

enum ServiceStatus {
  draft
  published
  archived
}

enum ServiceVisibility {
  public
  portal_only
  link_only
}

enum PurchaseStatus {
  pending
  processing
  active
  complete
  cancelled
  failed
  refunded
}

enum PaymentProvider {
  stripe
  wise
  manual
}

enum BillingCadence {
  day
  week
  month
  year
}

// Using the SCOPE framework from https://youtu.be/it0g33UQxqM?si=8keI274e4S0pX34D.

model Service {
  id                                     String                                 @id @default(cuid())
  workspaceId                            String                                 @map("workspace_id")
  
  // 1. IDENTITY & MERCHANDISING
  name                                   String
  slug                                   String                                 @unique  // Generate from name automatically.            
  tagline                                String?
  description                            String?                                @db.Text
  category                               String?
  avatar                                 String?
  coverImage                             String?                                @map("cover_image")
  status                                 ServiceStatus                          @default(draft)
  visibility                             ServiceVisibility                      @default(public)

  active                                 Boolean                                @default(true)
  featured                               Boolean                                @default(false)


  createdAt                              DateTime                               @default(now()) @map("created_at")
  updatedAt                              DateTime                               @updatedAt @map("updated_at")
  deletedAt                              DateTime?                              @map("deleted_at")

  workspace                              Workspace                              @relation(fields: [workspaceId], references: [id])
  packages                               ServicePackage[]
  addOns                                 ServiceAddOn[]
  purchases                              ServicePurchase[]

  @@unique([workspaceId, slug])
  @@map("services")
}

model ServicePackage {
  id                                     String                                 @id @default(cuid())
  serviceId                              String                                 @map("service_id")
  name                                   String
  slug                                   String
  description                            String?                                @db.Text

  price                                  Decimal?                               @db.Decimal(10,2)
  currency                               String                                 @default("USD")

  pricingType                            PricingType                            @default(one_time)

  sortOrder                              Int                                    @default(0)

    // If recurring
  interval                               BillingCadence?                                                         
  intervalCount                          Int?                                   @map("interval_count")

  featured                               Boolean                                @default(false)
  active                                 Boolean                                @default(true)

  // Proposal generation
  lineItems                              Json?                                  @map("line_items") @default("[]")

  deliverables                           Json?                                  @default("[]")

  timeline                               Json?                                  @map("timeline") @default("[]")

   // Flexible JSON field for complex payment terms (e.g., instalments, milestones)

  paymentSchedule                        Json?                                  @map("payment_schedule") @default("[]")

  legalClauses                           Json?                                  @map("legal_clauses") @default("[]")

  // Structured policy for revisions (e.g., number of rounds, turnaround time, unit (per project, per deliverable, etc) etc.)

  revisionPolicy                         Json?                                  @map("revision_policy") @default("[]")
  paymentPreferences                     Json?                                  @map("payment_preferences") @default("{}") // Flexible JSON field for extensible payment options

  // Only executes via Public Storefront checkout
  autoCreateProject                      Boolean                                @default(true) @map("auto_create_project")
  autoCreateCompany                      Boolean                                @default(true) @map("auto_create_company")
  autoSendBriefForm                      Boolean                                @default(true) @map("auto_send_brief_form")
  autoSendPortalInvite                   Boolean                                @default(true) @map("auto_send_portal_invite")
  briefFormId                            String?                                @map("brief_form_id")

  autoApplyRevisionPolicy                Boolean                                @default(true) @map("auto_apply_revision_policy")
  autoApplyPaymentSchedule               Boolean                                @default(true) @map("auto_apply_payment_schedule")
  autoApplyLegalClauses                  Boolean                                @default(true) @map("auto_apply_legal_clauses")

  createdAt                              DateTime                               @default(now()) @map("created_at")
  updatedAt                              DateTime                               @updatedAt @map("updated_at")
  deletedAt                              DateTime?                              @map("deleted_at")

  service                                Service                                @relation(fields: [serviceId], references: [id])
  purchases                              ServicePurchase[]
  addOns                                 ServicePackageAddOn[]

  @@unique([serviceId, slug])
  @@map("service_packages")
}


model ServiceAddOn {
  id                                     String                                 @id @default(cuid())
  serviceId                              String                                 @map("service_package_id")
  name                                   String
  description                            String?                                @db.Text
  price                                  Decimal                                @db.Decimal(10, 2)
  currency                               String                                 @default("USD")
  sortOrder                              Int                                    @default(0) @map("sort_order")
  stripePriceId                          String?                                @map("stripe_price_id")
  active                                 Boolean                                @default(true)

  createdAt                              DateTime                               @default(now()) @map("created_at")
  updatedAt                              DateTime                               @updatedAt @map("updated_at")
  deletedAt                              DateTime?                              @map("deleted_at")

  service                                Service                                @relation(fields: [serviceId], references: [id])
  purchases                              ServicePurchaseAddOn[]
  packages                               ServicePackageAddOn[]


  @@index([serviceId])
  @@map("service_add_ons")
}

model ServicePackageAddOn {
  packageId                              String
  addOnId                                String

  package                                ServicePackage                         @relation(fields: [packageId], references: [id], onDelete: Cascade)
  addOn                                  ServiceAddOn                           @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([packageId, addOnId])
}

model ServicePurchase {
  id                                     String                                 @id @default(cuid())
  workspaceId                            String                                 @map("workspace_id")
  serviceId                              String                                 @map("service_id")
  packageId                              String                                 @map("package_id")
  buyerName                              String                                 @map("buyer_name")
  buyerEmail                             String                                 @map("buyer_email")
  buyerCompany                           String?                                @map("buyer_company")
  companyId                              String?                                @map("company_id")
  contactId                              String?                                @map("contact_id")
  projectId                              String?                                @map("project_id")
  retainerId                             String?                                @map("retainer_id")
  invoiceId                              String?                                @map("invoice_id")
  status                                 PurchaseStatus                         @default(pending)
  provider                               PaymentProvider?                       @map("provider")
  serviceSnapshot                        Json                                   @default("{}") @map("service_snapshot")
  packageSnapshot                        Json                                   @default("{}") @map("package_snapshot")
  baseAmount                             Decimal                                @map("base_amount") @db.Decimal(10, 2)
  addOnsAmount                           Decimal                                @default(0) @map("add_ons_amount") @db.Decimal(10, 2)
  discountAmount                         Decimal                                @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount                              Decimal                                @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount                            Decimal                                @map("total_amount") @db.Decimal(10, 2)
  currency                               String                                 @default("USD") @db.VarChar(3)
  stripeCustomerId                       String?                                @map("stripe_customer_id")
  stripePaymentIntentId                  String?                                @unique @map("stripe_payment_intent_id")
  stripeSubscriptionId                   String?                                @unique @map("stripe_subscription_id")
  wisePaymentReference                   String?                                @unique @map("wise_payment_reference")
  wiseConfirmedAt                        DateTime?                              @map("wise_confirmed_at")
  purchasedAt                            DateTime                               @default(now()) @map("purchased_at")
  cancelledAt                            DateTime?                              @map("cancelled_at")
  refundedAt                             DateTime?                              @map("refunded_at")
  createdAt                              DateTime                               @default(now()) @map("created_at")
  updatedAt                              DateTime                               @updatedAt @map("updated_at")
  workspace                              Workspace                              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  service                                Service                                @relation(fields: [serviceId], references: [id])
  package                                ServicePackage                         @relation(fields: [packageId], references: [id])
  addOns                                 ServicePurchaseAddOn[]

  @@index([workspaceId])
  @@index([serviceId])
  @@index([packageId])

  @@index([buyerEmail])

  @@index([status])

  @@map("service_purchases")
}

model ServicePurchaseAddOn {
  id                                     String                                 @id @default(cuid())
  purchaseId                             String
  addOnId                                String
  price                                  Decimal                                @db.Decimal(10, 2)

  snapshot                               Json                                   @default("{}")
  addOn                                  ServiceAddOn                           @relation(fields: [addOnId], references: [id])
  purchase                               ServicePurchase                        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  @@index([purchaseId])
  @@map("service_purchase_add_ons")
}